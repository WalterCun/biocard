---
// Public Profile Page - SSR (Dynamic)
// Route: /[username]
import BaseLayout from '../../layouts/BaseLayout.astro';

// Enable SSR for dynamic routes
export const prerender = false;

const { username } = Astro.params;

// Fetch profile data from API
// In production, this would be: const response = await fetch(`${import.meta.env.API_URL}/profiles/${username}`)
const profile = {
  username,
  displayName: 'Tu Nombre',
  bio: 'Tu bio aquí - Creador de contenido',
  avatar: 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + username,
  theme: 'dark',
  backgroundColor: '#1a1a2e',
  backgroundImage: null,
  links: [
    { id: 1, title: 'Instagram', url: 'https://instagram.com', icon: '📸', isActive: true },
    { id: 2, title: 'YouTube', url: 'https://youtube.com', icon: '🎬', isActive: true },
    { id: 3, title: 'Mi Tienda', url: 'https://tu-tienda.com', icon: '🛒', isActive: true },
    { id: 4, title: 'Contacto', url: 'mailto:tu@email.com', icon: '✉️', isActive: true },
  ],
  socialLinks: [
    { platform: 'twitter', url: 'https://twitter.com' },
    { platform: 'tiktok', url: 'https://tiktok.com' },
  ]
};

// Apply theme styles
const themeStyles = `
  body {
    background: ${profile.backgroundImage 
      ? `url(${profile.backgroundImage}) center/cover no-repeat fixed` 
      : profile.backgroundColor};
  }
`;
---

<BaseLayout title={`${profile.displayName} (@${username}) | BioCard`}>
  <style set:html={themeStyles} />
  
  <div class="min-h-screen bg-black/50 backdrop-blur-sm">
    <!-- Profile Header -->
    <div class="container max-w-md mx-auto px-4 py-8">
      <div class="text-center mb-8">
        <!-- Avatar -->
        <div class="relative inline-block mb-4">
          <img 
            src={profile.avatar} 
            alt={profile.displayName}
            class="w-24 h-24 rounded-full border-4 border-white/20 mx-auto"
          />
        </div>
        
        <!-- Display Name -->
        <h1 class="text-2xl font-bold text-white mb-1">
          {profile.displayName}
        </h1>
        
        <!-- Username -->
        <p class="text-gray-400 text-sm mb-3">
          @{username}
        </p>
        
        <!-- Bio -->
        {profile.bio && (
          <p class="text-gray-300 text-sm mb-4">
            {profile.bio}
          </p>
        )}
        
        <!-- Social Links -->
        {profile.socialLinks && profile.socialLinks.length > 0 && (
          <div class="flex justify-center gap-3 mb-4">
            {profile.socialLinks.map((social: any) => (
              <a 
                href={social.url} 
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 flex items-center justify-center bg-white/10 rounded-full hover:bg-white/20 transition"
              >
                {social.platform === 'twitter' && '𝕏'}
                {social.platform === 'instagram' && '📸'}
                {social.platform === 'tiktok' && '🎵'}
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- Links -->
      <div class="space-y-3">
        {profile.links.map((link: any) => (
          <a 
            href={link.url}
            target={link.url.startsWith('http') ? '_blank' : '_self'}
            rel={link.url.startsWith('http') ? 'noopener noreferrer' : ''}
            class="block w-full p-4 bg-white/10 hover:bg-white/20 rounded-xl transition-all duration-200 flex items-center gap-4"
          >
            <span class="text-2xl">{link.icon}</span>
            <span class="font-medium text-white">{link.title}</span>
            <span class="ml-auto text-white/50">→</span>
          </a>
        ))}
      </div>

      <!-- Footer -->
      <div class="mt-8 text-center">
        <p class="text-gray-500 text-xs">
          Powered by <a href="/" class="text-purple-400 hover:text-purple-300">BioCard</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>