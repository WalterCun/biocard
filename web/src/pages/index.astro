---
// Landing page - Static (SSG)
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="BioCard - Link in Bio + Tarjeta Digital + Rewards">
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-900 via-purple-900 to-pink-900">
    <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-20"></div>
    
    <div class="relative z-10 text-center px-4 max-w-4xl">
      <h1 class="text-5xl md:text-7xl font-display font-bold text-white mb-6">
        Tu Link en Bio
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-pink-400">
          & Tarjeta Digital
        </span>
      </h1>
      
      <p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-2xl mx-auto">
        La plataforma todo-en-uno para creadores y negocios en Latinoamérica
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/admin/register" 
          class="px-8 py-4 bg-amber-500 hover:bg-amber-400 text-gray-900 font-semibold rounded-full transition-all transform hover:scale-105"
        >
          Comenzar Gratis
        </a>
        <a 
          href="#features" 
          class="px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-full hover:bg-white/10 transition-all"
        >
          Ver Features
        </a>
      </div>

      <!-- Preview Mockup -->
      <div class="mt-16 relative">
        <div class="inline-block p-1 bg-gradient-to-r from-amber-400 via-pink-500 to-purple-500 rounded-3xl">
          <div class="bg-gray-900 rounded-2xl p-2 md:p-4 max-w-sm mx-auto">
            <div class="text-center">
              <div class="w-20 h-20 mx-auto bg-gradient-to-r from-purple-500 to-pink-500 rounded-full mb-4"></div>
              <h3 class="text-white font-semibold text-lg">@tuusuario</h3>
              <p class="text-gray-400 text-sm mb-4">Tu bio aquí</p>
            </div>
            <div class="space-y-2">
              <div class="h-12 bg-gray-800 rounded-lg"></div>
              <div class="h-12 bg-gray-800 rounded-lg"></div>
              <div class="h-12 bg-gray-800 rounded-lg"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-20 bg-gray-900">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-display font-bold text-white text-center mb-12">
        Todo lo que necesitas
      </h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="p-6 bg-gray-800 rounded-2xl hover:bg-gray-700 transition">
          <div class="w-12 h-12 bg-purple-500 rounded-lg mb-4 flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-2">Links Ilimitados</h3>
          <p class="text-gray-400">Crea todos los enlaces que necesites y organízalos como quieras</p>
        </div>

        <!-- Feature 2 -->
        <div class="p-6 bg-gray-800 rounded-2xl hover:bg-gray-700 transition">
          <div class="w-12 h-12 bg-amber-500 rounded-lg mb-4 flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-2">Themes Personalizados</h3>
          <p class="text-gray-400">Elige entre múltiples temas o crea el tuyo propio</p>
        </div>

        <!-- Feature 3 -->
        <div class="p-6 bg-gray-800 rounded-2xl hover:bg-gray-700 transition">
          <div class="w-12 h-12 bg-pink-500 rounded-lg mb-4 flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-2">Analytics</h3>
          <p class="text-gray-400">Conoce tu audiencia con métricas detalladas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20 bg-gray-900">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-display font-bold text-white text-center mb-12">
        Precios simples
      </h2>
      
      <div class="grid md:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <!-- Free -->
        <div class="p-6 bg-gray-800 rounded-2xl border border-gray-700">
          <h3 class="text-lg font-semibold text-white mb-2">Free</h3>
          <div class="text-4xl font-bold text-white mb-4">$0<span class="text-lg text-gray-400">/mes</span></div>
          <ul class="space-y-2 text-gray-400 mb-6">
            <li>✅ 5 links</li>
            <li>✅ Temas básicos</li>
            <li>✅ QR Code</li>
            <li>❌ Analytics</li>
          </ul>
          <a href="/admin/register" class="block text-center py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-600">Comenzar</a>
        </div>

        <!-- Basic -->
        <div class="p-6 bg-gray-800 rounded-2xl border border-purple-500">
          <div class="text-xs text-purple-400 mb-1">MÁS VENDIDO</div>
          <h3 class="text-lg font-semibold text-white mb-2">Basic</h3>
          <div class="text-4xl font-bold text-white mb-4">$3.99<span class="text-lg text-gray-400">/mes</span></div>
          <ul class="space-y-2 text-gray-400 mb-6">
            <li>✅ 25 links</li>
            <li>✅ Todos los temas</li>
            <li>✅ Analytics</li>
            <li>✅ Custom domain</li>
          </ul>
          <a href="/admin/register" class="block text-center py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-500">Comenzar</a>
        </div>

        <!-- Pro -->
        <div class="p-6 bg-gray-800 rounded-2xl border border-gray-700">
          <h3 class="text-lg font-semibold text-white mb-2">Pro</h3>
          <div class="text-4xl font-bold text-white mb-4">$7.99<span class="text-lg text-gray-400">/mes</span></div>
          <ul class="space-y-2 text-gray-400 mb-6">
            <li>✅ Links ilimitados</li>
            <li>✅ Ecommerce</li>
            <li>✅ Donations</li>
            <li>✅ Rewards</li>
          </ul>
          <a href="/admin/register" class="block text-center py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-600">Comenzar</a>
        </div>

        <!-- Enterprise -->
        <div class="p-6 bg-gray-800 rounded-2xl border border-gray-700">
          <h3 class="text-lg font-semibold text-white mb-2">Enterprise</h3>
          <div class="text-4xl font-bold text-white mb-4">$19.99<span class="text-lg text-gray-400">/mes</span></div>
          <ul class="space-y-2 text-gray-400 mb-6">
            <li>✅ Todo Pro</li>
            <li>✅ Team members</li>
            <li>✅ API Access</li>
            <li>✅ White-label</li>
          </ul>
          <a href="/admin/register" class="block text-center py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-600">Comenzar</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-r from-purple-900 to-pink-900">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-4xl font-display font-bold text-white mb-6">
        ¿Listo para empezar?
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Crea tu perfil en segundos
      </p>
      <a 
        href="/admin/register" 
        class="inline-block px-8 py-4 bg-amber-500 hover:bg-amber-400 text-gray-900 font-semibold rounded-full transition-all"
      >
        Crear mi BioCard gratis
      </a>
    </div>
  </section>
</BaseLayout>