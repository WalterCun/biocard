# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://user:password@localhost:5432/biocard"

# ==========================================
# AUTH - NEXTAUTH
# ==========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# ==========================================
# AUTH PROVIDERS
# ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ==========================================
# STRIPE (Payments)
# ==========================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ==========================================
# PAYPHONE (Ecuador)
# ==========================================
PAYPHONE_CLIENT_ID=
PAYPHONE_CLIENT_SECRET=
PAYPHONE_BASE_URL=https://api.payphone.com

# ==========================================
# PAYPAL
# ==========================================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ==========================================
# MAILCHIMP
# ==========================================
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER=us1

# ==========================================
# AWS S3 (File Storage)
# ==========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=biocard-files