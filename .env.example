# BioCard Environment Variables

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/biocard
REDIS_URL=redis://localhost:6379

# ==========================================
# AUTH
# ==========================================
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ==========================================
# STRIPE (Payments)
# ==========================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ==========================================
# PAYPHONE (Ecuador)
# ==========================================
PAYPHONE_CLIENT_ID=your_client_id
PAYPHONE_CLIENT_SECRET=your_client_secret
PAYPHONE_BASE_URL=https://api.payphone.com

# ==========================================
# PAYPAL
# ==========================================
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_client_secret
PAYPAL_MODE=sandbox

# ==========================================
# MAILCHIMP
# ==========================================
MAILCHIMP_API_KEY=xxx-us1
MAILCHIMP_SERVER=us1

# ==========================================
# AWS S3 (File Storage)
# ==========================================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=biocard-files

# ==========================================
# FRONTEND
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# CUSTOM DOMAINS
# ==========================================
CUSTOM_DOMAIN_VERIFICATION_TOKEN=random_token_here